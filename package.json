{
  "name": "opencode-anthropic-dark-auth",
  "version": "1.0.0",
  "description": "OpenCode plugin that uses your Claude Code credentials — no separate login needed.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "anthropic",
    "auth",
    "claude",
    "opencode",
    "plugin"
  ],
  "author": {
    "name": "DarkRed",
    "url": "https://github.com/JDis03"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JDis03/opencode-anthropic-dark-auth.git"
  },
  "bugs": {
    "url": "https://github.com/JDis03/opencode-anthropic-dark-auth/issues"
  },
  "homepage": "https://github.com/JDis03/opencode-anthropic-dark-auth#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "4.1.10"
  }
}
